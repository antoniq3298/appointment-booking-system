# Copy this file to .env and fill in real values.
# Any missing value below makes that feature fall back to logging to the console instead of sending.

PORT=3000
JWT_SECRET=dev_secret_change_later
APP_BASE_URL=http://localhost:3000

# SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Appointment Booking <no-reply@example.com>"

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
